<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="onepage_checkout" name="Onepage Checkout">
        <t t-call="website.layout">
            <t t-set="additional_title">Shop - Checkout</t>

            <t t-set="order" t-value="website_sale_order"/>
            <div id="wrap" class="oe_website_sale o_website_sale_checkout">
                <div class="container py-4">

                    <h1 class="mb-4"><em>Checkout</em></h1>

                    <div class="row">
                        <!-- ════════  LEFT COLUMN: accordion panels  ════════ -->
                        <div class="col-lg-8">
                            <div id="onepage_accordion">

                                <!-- ── 1. BILLING INFORMATION ──────────── -->
                                <t t-if="config.billing_panel">
                                    <div t-attf-class="onepage-panel #{'panel-open' if open_panel == 'billing' else 'panel-pending'}" id="billing_panel_wrap">
                                        <div class="onepage-panel-header"
                                             data-target="billing_content"
                                             t-att-data-open="'1' if open_panel == 'billing' else '0'">
                                            <span t-esc="config.billing_label"/>
                                            <i t-attf-class="fa float-end onepage-chevron
                                                             #{'fa-chevron-up' if open_panel == 'billing' else 'fa-chevron-down'}"/>
                                        </div>
                                        <div class="onepage-panel-content"
                                             id="billing_content"
                                             t-att-style="'' if open_panel == 'billing' else 'display:none'">

                                            <h3 class="text-center my-3">Billing Address</h3>

                                            <t t-foreach="billings" t-as="partner">
                                                <div t-attf-class="onepage-address-card mb-2 p-3 border rounded
                                                                   #{'selected' if partner.id == order.partner_invoice_id.id else ''}"
                                                     t-att-data-partner-id="partner.id"
                                                     data-address-type="billing">
                                                    <t t-if="partner.parent_id">
                                                        <t t-esc="partner.parent_id.name"/>,
                                                    </t>
                                                    <t t-esc="partner.name"/><br/>
                                                    <t t-if="partner.street"><t t-esc="partner.street"/><br/></t>
                                                    <t t-if="partner.street2"><t t-esc="partner.street2"/><br/></t>
                                                    <t t-if="partner.city"><t t-esc="partner.city"/></t>
                                                    <t t-if="partner.state_id"> <t t-esc="partner.state_id.code"/></t>
                                                    <t t-if="partner.zip"> <t t-esc="partner.zip"/></t>
                                                    <t t-if="partner.city or partner.state_id or partner.zip"><br/></t>
                                                    <t t-if="partner.country_id"><t t-esc="partner.country_id.name"/></t>
                                                </div>
                                            </t>

                                            <div class="text-center my-3">
                                                <button type="button"
                                                        class="btn btn-dark onepage-continue"
                                                        t-att-data-next="not only_services and config.shipping_panel and 'shipping_content'
                                                                        or delivery_has_storable and config.delivery_panel and 'delivery_content'
                                                                        or 'payment_content'">
                                                    <i class="fa fa-check"/> Continue
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </t>

                                <!-- ── 2. SHIPPING INFORMATION ─────────── -->
                                <t t-if="not only_services and config.shipping_panel">
                                    <div t-attf-class="onepage-panel #{'panel-open' if open_panel == 'shipping' else 'panel-pending'}" id="shipping_panel_wrap">
                                        <div class="onepage-panel-header"
                                             data-target="shipping_content"
                                             t-att-data-open="'1' if open_panel == 'shipping' else '0'">
                                            <span t-esc="config.shipping_label"/>
                                            <i t-attf-class="fa float-end onepage-chevron
                                                             #{'fa-chevron-up' if open_panel == 'shipping' else 'fa-chevron-down'}"/>
                                        </div>
                                        <div class="onepage-panel-content"
                                             id="shipping_content"
                                             t-att-style="'' if open_panel == 'shipping' else 'display:none'">

                                            <h3 class="text-center my-3">Shipping Address</h3>

                                            <div class="mb-3">
                                                <a t-attf-href="/shop/address?mode=shipping&amp;callback=/shop/checkout?open_panel=shipping"
                                                   class="btn btn-secondary">
                                                    <i class="fa fa-plus"/> Add an address
                                                </a>
                                            </div>

                                            <t t-foreach="shippings" t-as="partner">
                                                <div t-attf-class="onepage-address-card mb-2 p-3 border rounded
                                                                   #{'selected' if partner.id == order.partner_shipping_id.id else ''}"
                                                     t-att-data-partner-id="partner.id"
                                                     data-address-type="shipping">
                                                    <t t-if="partner.parent_id">
                                                        <t t-esc="partner.parent_id.name"/>,
                                                    </t>
                                                    <t t-esc="partner.name"/><br/>
                                                    <t t-if="partner.street"><t t-esc="partner.street"/><br/></t>
                                                    <t t-if="partner.street2"><t t-esc="partner.street2"/><br/></t>
                                                    <t t-if="partner.city"><t t-esc="partner.city"/></t>
                                                    <t t-if="partner.state_id"> <t t-esc="partner.state_id.code"/></t>
                                                    <t t-if="partner.zip"> <t t-esc="partner.zip"/></t>
                                                    <t t-if="partner.city or partner.state_id or partner.zip"><br/></t>
                                                    <t t-if="partner.country_id"><t t-esc="partner.country_id.name"/></t>
                                                </div>
                                            </t>

                                            <div class="text-center my-3">
                                                <button type="button"
                                                        class="btn btn-dark onepage-continue"
                                                        t-att-data-next="delivery_has_storable and config.delivery_panel and 'delivery_content' or 'payment_content'">
                                                    <i class="fa fa-check"/> Continue
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </t>

                                <!-- ── 3. DELIVERY METHOD ──────────────── -->
                                <t t-if="delivery_has_storable and config.delivery_panel">
                                    <div t-attf-class="onepage-panel #{'panel-open' if open_panel == 'delivery' else 'panel-pending'}" id="delivery_panel_wrap">
                                        <div class="onepage-panel-header"
                                             data-target="delivery_content"
                                             t-att-data-open="'1' if open_panel == 'delivery' else '0'">
                                            <span t-esc="config.delivery_label"/>
                                            <i t-attf-class="fa float-end onepage-chevron
                                                             #{'fa-chevron-up' if open_panel == 'delivery' else 'fa-chevron-down'}"/>
                                        </div>
                                        <div class="onepage-panel-content"
                                             id="delivery_content"
                                             t-att-style="'' if open_panel == 'delivery' else 'display:none'">

                                            <div t-if="deliveries" id="delivery_carrier">
                                                <div class="card border-0" id="delivery_method">
                                                    <ul class="list-group">
                                                        <t t-foreach="deliveries" t-as="delivery">
                                                            <li class="list-group-item o_delivery_carrier_select">
                                                                <t t-call="website_sale.payment_delivery_methods"/>
                                                            </li>
                                                        </t>
                                                    </ul>
                                                </div>
                                            </div>
                                            <div t-else="" class="text-muted text-center py-3">
                                                No delivery methods available for your address.
                                            </div>

                                            <div class="text-center my-3">
                                                <button type="button"
                                                        class="btn btn-dark onepage-continue"
                                                        data-next="payment_content">
                                                    <i class="fa fa-check"/> Continue
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </t>

                                <!-- ── 4. ORDER PREVIEW &amp; PAYMENT ─────── -->
                                <t t-if="config.payment_panel">
                                    <div t-attf-class="onepage-panel #{'panel-open' if open_panel == 'payment' else 'panel-pending'}" id="payment_panel_wrap">
                                        <div class="onepage-panel-header"
                                             data-target="payment_content"
                                             t-att-data-open="'1' if open_panel == 'payment' else '0'">
                                            <span t-esc="config.payment_label"/>
                                            <i t-attf-class="fa float-end onepage-chevron
                                                             #{'fa-chevron-up' if open_panel == 'payment' else 'fa-chevron-down'}"/>
                                        </div>
                                        <div class="onepage-panel-content"
                                             id="payment_content"
                                             t-att-style="'' if open_panel == 'payment' else 'display:none'">

                                            <!-- ── Cart lines ────────────── -->
                                            <div id="onepage_cart_lines">
                                            <t t-foreach="website_sale_order.order_line" t-as="line">
                                                <t t-if="not line.is_delivery">
                                                    <div class="d-flex align-items-center py-2 border-bottom onepage-cart-line"
                                                         t-att-data-line-id="line.id"
                                                         t-att-data-product-id="line.product_id.id">
                                                        <div class="me-3" style="width:60px;">
                                                            <img t-att-src="'/web/image/product.product/%s/image_128' % line.product_id.id"
                                                                 class="img-fluid" alt="Product"/>
                                                        </div>
                                                        <div class="flex-grow-1">
                                                            <strong t-esc="line.product_id.display_name"/>
                                                            <div class="text-muted small"
                                                                 t-if="line.name and line.name != line.product_id.display_name">
                                                                <t t-esc="line.name"/>
                                                            </div>
                                                            <a href="#" class="text-primary small onepage-cart-remove">Remove</a>
                                                        </div>
                                                        <div class="d-flex align-items-center me-3">
                                                            <button class="btn btn-sm btn-outline-dark onepage-cart-minus">&#8722;</button>
                                                            <span class="mx-2 onepage-cart-qty" t-esc="int(line.product_uom_qty)"/>
                                                            <button class="btn btn-sm btn-outline-dark onepage-cart-plus">+</button>
                                                        </div>
                                                        <div class="text-end onepage-cart-price" style="min-width:90px;">
                                                            <span t-field="line.price_subtotal"
                                                                  t-options='{"widget": "monetary", "display_currency": website_sale_order.currency_id}'/>
                                                        </div>
                                                    </div>
                                                </t>
                                            </t>
                                            </div>

                                            <!-- ── Totals ────────────────── -->
                                            <table class="table table-sm table-borderless mt-3 mb-0">
                                                <tr t-if="website_sale_order.carrier_id">
                                                    <td class="text-muted">Delivery</td>
                                                    <td class="text-end">
                                                        <span class="monetary_field"
                                                              t-field="website_sale_order.amount_delivery"
                                                              style="white-space:nowrap"
                                                              t-options='{"widget": "monetary", "display_currency": website_sale_order.currency_id}'/>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td class="text-muted">Subtotal</td>
                                                    <td class="text-end">
                                                        <span class="monetary_field"
                                                              t-field="website_sale_order.amount_untaxed"
                                                              style="white-space:nowrap"
                                                              t-options='{"widget": "monetary", "display_currency": website_sale_order.currency_id}'/>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td class="text-muted">Taxes</td>
                                                    <td class="text-end">
                                                        <span class="monetary_field"
                                                              t-field="website_sale_order.amount_tax"
                                                              style="white-space:nowrap"
                                                              t-options='{"widget": "monetary", "display_currency": website_sale_order.currency_id}'/>
                                                    </td>
                                                </tr>
                                                <tr class="fw-bold border-top">
                                                    <td>Total</td>
                                                    <td class="text-end">
                                                        <span class="monetary_field"
                                                              t-field="website_sale_order.amount_total"
                                                              style="white-space:nowrap"
                                                              t-options='{"widget": "monetary", "display_currency": website_sale_order.currency_id}'/>
                                                    </td>
                                                </tr>
                                            </table>

                                            <!-- ── Discount code ─────────── -->
                                            <div class="my-3">
                                                <form action="/shop/pricelist" method="POST">
                                                    <input type="hidden" name="csrf_token"
                                                           t-att-value="request.csrf_token()"/>
                                                    <div class="input-group">
                                                        <input type="text" name="promo"
                                                               class="form-control"
                                                               placeholder="Discount code..."/>
                                                        <button type="submit"
                                                                class="btn btn-dark">
                                                            Apply
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>

                                            <!-- ── Payment form ──────────── -->
                                            <t t-if="not errors and website_sale_order.amount_total">
                                                <div t-if="payment_methods_sudo or tokens_sudo"
                                                     id="payment_method"
                                                     class="o_not_editable">
                                                    <t t-call="payment.form"/>
                                                </div>
                                                <div t-else="" class="mt-2">
                                                    <a t-attf-href="/web#action=#{payment_action_id}"
                                                       class="text-primary" groups="base.group_system">
                                                        <i class="fa fa-arrow-right"/> Add payment acquirers
                                                    </a>
                                                </div>
                                                <!-- Pay button outside form (native pattern) -->
                                                <div t-if="payment_methods_sudo or tokens_sudo"
                                                     class="text-center mt-3">
                                                    <button name="o_payment_submit_button"
                                                            type="submit"
                                                            class="btn btn-primary btn-lg w-100"
                                                            disabled="true"
                                                            t-esc="submit_button_label"/>
                                                </div>
                                            </t>

                                            <!-- ── Free order ────────────── -->
                                            <t t-if="not errors and not website_sale_order.amount_total">
                                                <div class="text-center mt-3">
                                                    <a role="button"
                                                       class="btn btn-primary btn-lg w-100 a-submit"
                                                       href="/shop/confirm_order">
                                                        <i class="fa fa-lock"/> Confirm Order
                                                    </a>
                                                </div>
                                            </t>

                                            <!-- ── Errors ────────────────── -->
                                            <t t-if="errors">
                                                <t t-foreach="errors" t-as="error">
                                                    <div class="alert alert-danger mt-3" role="alert">
                                                        <h4 t-esc="error[0]"/>
                                                        <span t-esc="error[1]"/>
                                                    </div>
                                                </t>
                                            </t>
                                        </div>
                                    </div>
                                </t>

                            </div><!-- /onepage_accordion -->

                            <!-- ── Return to Cart ─────────────────────── -->
                            <div class="mt-3 mb-5">
                                <a href="/shop/cart" class="btn btn-secondary onepage-btn-return">
                                    <i class="fa fa-chevron-left"/> Return to Cart
                                </a>
                            </div>

                        </div><!-- /col-lg-8 -->

                        <!-- ════════  RIGHT COLUMN: order summary  ════════ -->
                        <div class="col-lg-4">
                            <div class="o_onepage_summary">
                                <table class="table table-sm table-borderless mb-0" id="cart_total">
                                    <tr id="order_delivery"
                                        t-att-style="'' if website_sale_order and website_sale_order.carrier_id else 'display:none'">
                                        <td class="text-muted">Delivery</td>
                                        <td class="text-end">
                                            <span class="monetary_field"
                                                  t-field="website_sale_order.amount_delivery"
                                                  style="white-space:nowrap"
                                                  t-options='{"widget": "monetary", "display_currency": website_sale_order.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr id="order_total_untaxed">
                                        <td class="text-muted">Subtotal</td>
                                        <td class="text-end">
                                            <span class="monetary_field"
                                                  t-field="website_sale_order.amount_untaxed"
                                                  style="white-space:nowrap"
                                                  t-options='{"widget": "monetary", "display_currency": website_sale_order.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr id="order_total_taxes">
                                        <td class="text-muted">Taxes</td>
                                        <td class="text-end">
                                            <span class="monetary_field"
                                                  t-field="website_sale_order.amount_tax"
                                                  style="white-space:nowrap"
                                                  t-options='{"widget": "monetary", "display_currency": website_sale_order.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr id="order_total" class="fw-bold border-top">
                                        <td>Total</td>
                                        <td class="text-end">
                                            <span class="monetary_field"
                                                  t-field="website_sale_order.amount_total"
                                                  style="white-space:nowrap"
                                                  t-options='{"widget": "monetary", "display_currency": website_sale_order.currency_id}'/>
                                        </td>
                                    </tr>
                                </table>
                                <div class="mt-3">
                                    <form action="/shop/pricelist" method="POST">
                                        <input type="hidden" name="csrf_token"
                                               t-att-value="request.csrf_token()"/>
                                        <div class="input-group">
                                            <input type="text" name="promo"
                                                   class="form-control"
                                                   placeholder="Discount code..."/>
                                            <button type="submit"
                                                    class="btn btn-dark">
                                                Apply
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div><!-- /col-lg-4 -->

                    </div><!-- /row -->
                </div><!-- /container -->
            </div><!-- /wrap -->
        </t>
    </template>

</odoo>
