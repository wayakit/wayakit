<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="action_tracking_service_logs" model="ir.actions.act_window">
        <field name="type">ir.actions.act_window</field>
        <field name="name">Tracking Logs</field>
        <field name="res_model">website.tracking.log</field>
        <field name="view_mode">tree,graph,pivot,form</field>
        <field name="context">{'default_service_id': active_id, 'search_default_filter_today': 1}</field>
        <field name="domain">[('service_id', '=', active_id)]</field>
    </record>

    <record id="website_tracking_service_view_form" model="ir.ui.view">
        <field name="name">website.tracking.service.view.form</field>
        <field name="model">website.tracking.service</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_tracking_service_logs)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-bar-chart"
                                string="Logs"/>
                    </div>
                    <field name="active" invisible="1"/>
                    <field name="show_lead_value" invisible="1"/>
                    <field name="is_custom_events_allowed" invisible="1"/>
                    <field name="api_is_available" invisible="1"/>

                    <widget name="web_ribbon" text="Archived" bg_color="bg-danger" invisible="active"/>

                    <div class="oe_title">
                        <h1><field name="display_name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="website_id" groups="website.group_multi_website"/>
                            <field name="type" required="1"/>
                            <field name="key_is_required" invisible="1"/>
                            <field name="key" required="type != 'odoo' and key_is_required" invisible="not key_is_required"/>
                        </group>
                        <group>
                            <field name="item_type"/>
                            <field name="category_type"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Options" name="options">
                            <group string="Custom Events" name="custom_events" invisible="not is_custom_events_allowed">
                                <field name="event_ids" nolabel="1" colspan="2" context="{'default_service_id': id}">
                                    <tree editable="bottom">
                                        <field name="service_type" column_invisible="1"/>
                                        <field name="type"/>
                                        <field name="name"/>
                                        <field name="active" widget="boolean_toggle"/>
                                    </tree>
                                </field>
                            </group>
                            <group class="o_label_nowrap" name="options">
                                <group string="Logging" name="logging">
                                    <field name="is_internal_logged" widget="boolean_toggle"/>
                                </group>
                                <group string="Leads" invisible="not show_lead_value">
                                    <field name="lead_value"/>
                                </group>
                                <group string="API" name="api_options" invisible="not api_is_available">
                                    <field name="api_is_active" string="Activate" widget="boolean_toggle"/>
                                    <field name="api_token" invisible="not api_is_active" required="api_is_active" class="o_text_overflow"/>
                                    <field name="api_test_code" invisible="not api_is_active"/>
                                    <field name="api_deactivate_pixel" widget="boolean_toggle" invisible="not api_is_active"/>
                                </group>
                            </group>
                        </page>
                        <page string="Advanced Matching" name="user_data">
                            <group class="o_label_nowrap">
                                <group colspan="4">
                                    <field name="track_customer_data_source" widget="radio" options="{'horizontal': true}"/>
                                </group>
                            </group>
                            <group string="Specify a customer data that should be sent">
                                 <group>
                                     <label for="track_id_external" string="External ID"/>
                                     <div class="o_row">
                                         <field name="track_id_external" widget="boolean_toggle"/>
                                         <span class="text-muted" invisible="not track_id_external">Type: </span>
                                         <field name="external_id_type" invisible="not track_id_external"/>
                                     </div>
                                     <field name="track_ip_address" string="IP Address" widget="boolean_toggle"/>
                                     <field name="track_user_agent" string="User Agent" widget="boolean_toggle"/>
                                     <separator/>
                                     <label for="track_user_name" string="Customer Name"/>
                                     <div class="o_row">
                                         <field name="track_user_name" widget="boolean_toggle"/>
                                         <span class="text-muted" invisible="not track_user_name">Hashed </span>
                                         <field name="user_name_is_hashed" invisible="not track_user_name"/>
                                     </div>
                                     <label for="track_email" string="Email"/>
                                     <div class="o_row">
                                         <field name="track_email" widget="boolean_toggle"/>
                                         <span class="text-muted" invisible="not track_email">Hashed </span>
                                         <field name="email_is_hashed" invisible="not track_email"/>
                                     </div>
                                     <label for="track_phone" string="Phone"/>
                                     <div class="o_row">
                                         <field name="track_phone" widget="boolean_toggle"/>
                                         <span class="text-muted" invisible="not track_phone">Hashed </span>
                                         <field name="phone_is_hashed" invisible="not track_phone"/>
                                     </div>
                                 </group>
                                 <group>
                                     <field name="track_country" string="Country" widget="boolean_toggle"/>
                                     <field name="track_state" string="State" widget="boolean_toggle"/>
                                     <field name="track_zip" string="ZIP" widget="boolean_toggle"/>
                                     <field name="track_city" string="City" widget="boolean_toggle"/>
                                     <label for="track_street" string="Street"/>
                                     <div class="o_row">
                                         <field name="track_street" widget="boolean_toggle"/>
                                         <span class="text-muted" invisible="not track_street">Hashed </span>
                                         <field name="street_is_hashed" invisible="not track_street"/>
                                     </div>
                                 </group>
                            </group>
                            <separator string="Please visit the Privacy and Data Use Guide for the current service" invisible="not privacy_url"/>
                            <field name="privacy_url" widget="url" invisible="not privacy_url"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="website_tracking_service_view_tree" model="ir.ui.view">
        <field name="name">website.tracking.service.view.tree</field>
        <field name="model">website.tracking.service</field>
        <field name="arch" type="xml">
            <tree decoration-muted="not active" decoration-info="api_is_active">
                <field name="sequence" widget="handle"/>
                <field name="website_id" optional="show" groups="website.group_multi_website"/>
                <field name="type"/>
                <field name="api_is_available" column_invisible="1"/>
                <field name="api_is_active" invisible="not api_is_available" optional="hide"/>
                <field name="key"/>
                <field name="is_internal_logged" optional="show"/>
                <button name="%(action_tracking_service_logs)d" type="action" icon="fa-bar-chart" string="" title="Show Logs"/>
                <field name="item_type" optional="hide"/>
                <field name="category_type" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>
    
    <record id="website_tracking_service_view_search" model="ir.ui.view">
        <field name="name">website.tracking.service.view.search</field>
        <field name="model">website.tracking.service</field>
        <field name="arch" type="xml">
            <search>
                <filter name="filter_is_internal_logged" string="With Internal Logging" domain="[('is_internal_logged', '=', True)]"/>
                <separator/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0">
                    <filter name="group_by_type" domain="[]" context="{'group_by': 'type'}"/>
                    <filter name="group_by_website" domain="[]" context="{'group_by': 'website_id'}" groups="website.group_multi_website"/>
                </group>
                <searchpanel view_types="list,graph">
                    <field name="type" string="Type" select="multi" icon="fa-bar-chart" />
                    <field name="website_id" string="Website" select="multi" icon="fa-globe" groups="website.group_multi_website"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="action_tracking_service_list" model="ir.actions.act_window">
        <field name="type">ir.actions.act_window</field>
        <field name="name">Tracking Services</field>
        <field name="res_model">website.tracking.service</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'active_test': False}</field>
    </record>

    <menuitem id="website_tracking_service_menu"
              name="Services"
              parent="website_tracking_menu"
              action="action_tracking_service_list"
              sequence="10"/>

</odoo>
