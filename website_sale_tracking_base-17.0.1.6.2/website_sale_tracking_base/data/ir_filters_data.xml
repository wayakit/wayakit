<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="filter_website_tracking_apps" model="ir.filters">
        <field name="name">Garazd Website Tracking</field>
        <field name="model_id">ir.module.module</field>
        <field name="domain">[("author", "ilike", "Garazd Creation"), '|', ("name", "like", "website_"), ("name", "like", "website_sale_")]</field>
        <field name="context">{'group_by': []}</field>
        <field name="sort">["name asc"]</field>
        <field name="action_id" ref="base.open_module_tree"/>
        <field name="user_id" eval="False"/>
    </record>

</odoo>
