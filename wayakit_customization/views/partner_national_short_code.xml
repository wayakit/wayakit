<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_partner_form_national_short_code" model="ir.ui.view">
            <field name="name">res.partner.form.national.short.code</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="priority">99</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='zip']" position="after">
                    <field name="x_national_short_code"
                           placeholder="e.g. RRRD2929"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>