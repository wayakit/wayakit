<odoo>
    <data>
        <record id="sale_order_trendyol_form" model="ir.ui.view">
            <field name="name">sale.order.trendyol.form</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='client_order_ref']" position="after">
                    <field name="trendyol_order_number" readonly="1" invisible="not trendyol_order_number"/>
                    <field name="trendyol_status" readonly="1" invisible="not trendyol_order_number"/>
                    <field name="trendyol_package_id" readonly="1" invisible="not trendyol_order_number"/>
                    <field name="trendyol_backend_id" readonly="1" invisible="not trendyol_order_number"/>
                </xpath>
            </field>
        </record>

        <record id="sale_order_trendyol_tree" model="ir.ui.view">
            <field name="name">sale.order.trendyol.tree</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
            <field name="arch" type="xml">
                <field name="amount_total" position="after">
                    <field name="trendyol_order_number" string="Trendyol #" optional="hide"/>
                    <field name="trendyol_status" string="Trendyol Status" optional="hide"/>
                </field>
            </field>
        </record>
    </data>
</odoo>
