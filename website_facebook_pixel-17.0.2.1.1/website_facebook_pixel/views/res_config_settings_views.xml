<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="website_config_settings_view_form" model="ir.ui.view">
        <field name="name">website.config.settings.view.form.inherit.website_facebook_pixel</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='google_analytics_setting']" position="after">
                <setting id="facebook_pixel_setting"
                         string="Facebook Pixel"
                         documentation="https://garazd.biz/en/blog/odoo/creating-a-facebook-pixel-and-activating-it-in-odoo-4"
                         help="Track website Activities, Improve your return on Advertising, Reach New and Existing Customers in Facebook Advertising">
                    <field name="has_facebook_pixel"/>
                    <div class="content-group" invisible="not has_facebook_pixel">
                        <div class="row mt16">
                            <label class="col-lg-3 o_light_label text-nowrap" string="Tracking ID" for="facebook_pixel_key"/>
                            <field name="facebook_pixel_key" placeholder="XXXXXXXXXXXXXXX" required="has_facebook_pixel"/>
                        </div>
                    </div>
                    <div invisible="not has_facebook_pixel" name="facebook_pixel_help" class="mt8">
                        <a href="https://www.facebook.com/business/help/952192354843755" class="oe_link" target="_blank">
                            <i class="oi oi-arrow-right"/> How to set up Facebook Pixel
                        </a>
                    </div>
                </setting>
            </xpath>
            <xpath expr="//setting[@id='website_cookies_bar_setting']/parent::block" position="inside">
                <setting id="facebook_pixel_consent_setting"
                         string="Facebook Pixel - Consent is Revoked (by default)"
                         help="The cookie consent for Facebook tracking is revoked by default for new visitors to the
                            website, in case, when the Consent Manager is specified.
                            Otherwise, when Consent Manager is 'None', a consent is granted always.">
                    <field name="fbp_cookies_consent_is_revoked"/>
                </setting>
            </xpath>
        </field>
    </record>

</odoo>
