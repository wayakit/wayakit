<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mcp_model_selection_wizard_form" model="ir.ui.view">
        <field name="name">ai.mcp.model.selection.wizard.form</field>
        <field name="model">ai.mcp.model.selection.wizard</field>
        <field name="arch" type="xml">
            <form string="Enable Models for MCP">
                <sheet>
                    <group>
                        <field name="model_ids" widget="many2many_tags"
                               options="{'no_create': True}"/>
                    </group>
                    <group string="Operations to allow on the selected models">
                        <field name="allow_read"/>
                        <field name="allow_create"/>
                        <field name="allow_write"/>
                        <field name="allow_unlink"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_enable_models" type="object"
                            string="Enable" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mcp_model_selection_wizard" model="ir.actions.act_window">
        <field name="name">Enable Models for MCP</field>
        <field name="res_model">ai.mcp.model.selection.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
