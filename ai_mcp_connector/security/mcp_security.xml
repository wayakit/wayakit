<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="group_mcp_user" model="res.groups">
            <field name="name">AI MCP Connector User</field>
            <field name="comment">Can see MCP configuration (read-only) and generate their own connection URL.</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_mcp_admin" model="res.groups">
            <field name="name">AI MCP Connector Administrator</field>
            <field name="comment">Can configure the MCP server: enable models, settings and view logs.</field>
            <field name="implied_ids" eval="[(4, ref('group_mcp_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <record id="rule_mcp_enabled_model_admin" model="ir.rule">
            <field name="name">MCP Enabled Models: administrators manage</field>
            <field name="model_id" ref="model_ai_mcp_enabled_model"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_mcp_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_mcp_apikeys_admin" model="ir.rule">
            <field name="name">MCP: administrators can see all API keys (Connections view)</field>
            <field name="model_id" ref="base.model_res_users_apikeys"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_mcp_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_mcp_enabled_model_user" model="ir.rule">
            <field name="name">MCP Enabled Models: users read-only</field>
            <field name="model_id" ref="model_ai_mcp_enabled_model"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_mcp_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>

    <data noupdate="1">
        <!-- System administrators automatically become MCP administrators -->
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('group_mcp_admin'))]"/>
        </record>
    </data>
</odoo>
