<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="myfatoorah_apple_pay_button_checkout"
              inherit_id="website_sale.payment"
              name="MyFatoorah Apple Pay Button Checkout">

        <xpath expr="//div[@id='o_payment_form_pay']" position="before">
            <div id="mf_apple_pay_wrapper" class="mb-3">
                <button type="button"
                        id="mf_apple_pay_btn"
                        class="btn btn-dark w-100 d-flex align-items-center justify-content-center"
                        style="min-height:48px;border-radius:6px;font-weight:600;">
                    <span style="font-size:18px;line-height:1;"></span>
                    <span class="ms-2">Pay with Apple Pay</span>
                </button>
            </div>
        </xpath>

    </template>

</odoo>