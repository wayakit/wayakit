<odoo>
    <record id="pricing_list_wizard_form" model="ir.ui.view">
        <field name="name">pricing.list.wizard.form</field>
        <field name="model">pricing.list.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Tier to Print">
                <group>
                    <field name="tier"/>
                </group>

                <footer>
                    <button name="action_print_report" string="Print" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_open_tier_wizard" model="ir.actions.act_window">
        <field name="name">Pricing List PDF</field>
        <field name="res_model">pricing.list.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="price_intelligence.model_product_master"/>
        <field name="binding_type">action</field>
    </record>
</odoo>